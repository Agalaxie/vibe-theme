{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{ "slug": "primary",    "color": "#228B22", "name": "Primary"    },
				{ "slug": "primary-dark", "color": "#0f5132", "name": "Primary Dark" },
				{ "slug": "secondary",  "color": "#64748b", "name": "Secondary"  },
				{ "slug": "accent",     "color": "#f59e0b", "name": "Accent"     },
				{ "slug": "background", "color": "#ffffff", "name": "Background" },
				{ "slug": "foreground", "color": "#0f172a", "name": "Foreground" },
				{ "slug": "muted",      "color": "#f1f5f9", "name": "Muted"      }
			],
			"gradients": [
				{
					"slug": "hero",
					"name": "Hero",
					"gradient": "linear-gradient(135deg, #0f5132 0%, #228B22 50%, #4ade80 100%)"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "Sans",
					"fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif"
				},
				{
					"slug": "serif",
					"name": "Serif",
					"fontFamily": "Georgia, Cambria, 'Times New Roman', Times, serif"
				},
				{
					"slug": "display",
					"name": "Display",
					"fontFamily": "'Fraunces', Georgia, serif",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 900",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": [ "https://fonts.gstatic.com/s/fraunces/v31/6NUh8FyLNQOQZAnv9bYWvbdPi7PvGnf9aiz_V7zNjf4r.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "sm",   "size": "0.875rem", "name": "Small"        },
				{ "slug": "base", "size": "1rem",     "name": "Base"         },
				{ "slug": "lg",   "size": "1.25rem",  "name": "Large"        },
				{ "slug": "xl",   "size": "1.5rem",   "name": "Extra Large"  },
				{ "slug": "2xl",  "size": "2rem",     "name": "Double Extra" }
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vh", "vw"],
			"spacingScale": {
				"operator": "*",
				"increment": 1.5,
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text":       "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize":   "var(--wp--preset--font-size--base)",
			"lineHeight": "1.6"
		},
		"elements": {
			"h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "var(--wp--preset--font-size--2xl)", "fontWeight": "700", "lineHeight": "1.1", "letterSpacing": "-0.02em" } },
			"h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "var(--wp--preset--font-size--xl)",  "fontWeight": "600", "lineHeight": "1.2", "letterSpacing": "-0.01em" } },
			"h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "var(--wp--preset--font-size--lg)",  "fontWeight": "600", "lineHeight": "1.3" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text":       "var(--wp--preset--color--background)"
				},
				"spacing": { "padding": { "top": "0.75rem", "right": "1.25rem", "bottom": "0.75rem", "left": "1.25rem" } }
			}
		}
	}
}
